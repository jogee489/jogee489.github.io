      <span>Java</span><span>·</span>
      <span>Python</span><span>·</span>
      <span>Node.js</span><span>·</span>
      <span>Flutter</span><span>·</span>
      <span>Kotlin</span><span>·</span>
      <span>Linux</span>
    </div>
  </div>

  <div class="hero-cue" aria-hidden="true">
    <span class="hero-cue-line"></span>
    <span>scroll</span>
  </div>
