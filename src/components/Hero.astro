    <div class="hero-meta" data-reveal>
      <span class="hero-status">
        <span class="hero-status-dot"></span>
        Available for freelance · jun '26
      </span>
    </div>

    <h1 class="hero-name">
      <span data-reveal style="--reveal-delay:80ms; display:block;"><em>JJ</em>&nbsp;Dorko<span class="hero-period">.</span></span>
