---
import TileBase from './TileBase.astro';
interface Props { screenshot?: string; }
const { screenshot } = Astro.props;

const stars = Array.from({ length: 40 }, (_, i) => ({
  left: `${(i * 37) % 100}%`,
  top: `${(i * 53) % 100}%`,
  opacity: 0.4 + (i % 3) * 0.2,
}));
const enemies = Array.from({ length: 10 });
---

<TileBase
  gradient="radial-gradient(circle at 30% 20%, oklch(0.4 0.18 290) 0%, oklch(0.15 0.08 270) 55%, oklch(0.07 0.04 260) 100%)"
  screenshot={screenshot}
>
  <!-- Wordmark -->
  <div style="position:absolute;inset:0;display:flex;align-items:flex-start;justify-content:flex-start;padding:20px 22px;pointer-events:none;z-index:1;">
    <span style="font-family:var(--serif);font-style:italic;color:rgba(255,255,255,0.92);font-size:clamp(28px,4.4vw,56px);line-height:0.95;letter-spacing:-0.5px;text-shadow:0 2px 14px rgba(0,0,0,0.25);">Unity / C#</span>
  </div>
  <!-- Game screen -->
  <div style="position:absolute;left:6%;right:6%;top:12%;bottom:12%;border-radius:6px;background:rgba(0,0,0,0.45);border:1px solid rgba(255,255,255,0.18);box-shadow:0 18px 36px rgba(0,0,0,0.4), inset 0 0 60px rgba(120,80,220,0.25);overflow:hidden;">
    <!-- Stars -->
    {stars.map(s => (
      <span style={`position:absolute;left:${s.left};top:${s.top};width:2px;height:2px;border-radius:50%;background:white;opacity:${s.opacity};display:inline-block;`}></span>
    ))}
    <!-- Enemy formation -->
    <div style="position:absolute;top:20%;left:50%;transform:translateX(-50%);display:grid;grid-template-columns:repeat(5,1fr);gap:10px;">
      {enemies.map(_ => (
        <span style="width:14px;height:10px;background:oklch(0.7 0.2 320);clip-path:polygon(0 50%, 50% 0, 100% 50%, 50% 100%);display:inline-block;"></span>
      ))}
    </div>
    <!-- Player ship -->
    <span style="position:absolute;bottom:14%;left:50%;transform:translateX(-50%);width:22px;height:14px;background:oklch(0.85 0.18 95);clip-path:polygon(50% 0, 100% 100%, 0 100%);display:inline-block;"></span>
    <!-- Laser -->
    <span style="position:absolute;bottom:28%;left:50%;transform:translateX(-50%);width:2px;height:36px;background:oklch(0.85 0.18 95);box-shadow:0 0 8px oklch(0.85 0.2 95);display:inline-block;"></span>
  </div>
</TileBase>
