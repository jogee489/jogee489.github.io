---
import TileBase from './TileBase.astro';
interface Props { screenshot?: string; }
const { screenshot } = Astro.props;
---

<TileBase
  gradient="linear-gradient(160deg, oklch(0.75 0.1 220) 0%, oklch(0.55 0.15 240) 60%, oklch(0.4 0.13 270) 100%)"
  screenshot={screenshot}
>
  <!-- Wordmark -->
  <div style="position:absolute;inset:0;display:flex;align-items:flex-start;justify-content:flex-start;padding:20px 22px;pointer-events:none;">
    <span style="font-family:var(--serif);font-style:italic;color:rgba(255,255,255,0.92);font-size:clamp(28px,4.4vw,56px);line-height:0.95;letter-spacing:-0.5px;text-shadow:0 2px 14px rgba(0,0,0,0.25);">Flutter</span>
  </div>
  <!-- Sun + cloud -->
  <svg viewBox="0 0 200 200" style="position:absolute;top:18px;right:22px;width:78px;opacity:0.45;">
    <circle cx="120" cy="80" r="28" fill="white"/>
    <ellipse cx="80" cy="115" rx="48" ry="22" fill="white" opacity="0.85"/>
    <ellipse cx="105" cy="105" rx="38" ry="18" fill="white" opacity="0.85"/>
  </svg>
  <!-- Phone -->
  <svg viewBox="0 0 220 440" style="position:absolute;bottom:-40px;left:50%;width:56%;transform:translateX(-50%) rotate(6deg);filter:drop-shadow(0 18px 28px rgba(0,0,0,0.22));">
    <rect x="6" y="6" width="208" height="428" rx="34" ry="34" fill="rgba(15,15,15,0.92)" stroke="rgba(255,255,255,0.9)" stroke-width="1.2"/>
    <rect x="14" y="22" width="192" height="396" rx="22" ry="22" fill="rgba(255,255,255,0.06)"/>
    <rect x="86" y="14" width="48" height="10" rx="5" fill="rgba(0,0,0,0.6)"/>
  </svg>
</TileBase>
