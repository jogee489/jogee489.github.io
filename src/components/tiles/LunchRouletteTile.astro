---
import TileBase from './TileBase.astro';
interface Props { screenshot?: string; }
const { screenshot } = Astro.props;
---

<TileBase
  gradient="linear-gradient(135deg, oklch(0.55 0.2 145) 0%, oklch(0.42 0.16 165) 50%, oklch(0.3 0.1 210) 100%)"
  screenshot={screenshot}
>
  <!-- Wordmark -->
  <div style="position:absolute;inset:0;display:flex;align-items:flex-start;justify-content:flex-start;padding:20px 22px;pointer-events:none;">
    <span style="font-family:var(--serif);font-style:italic;color:rgba(255,255,255,0.92);font-size:clamp(28px,4.4vw,56px);line-height:0.95;letter-spacing:-0.5px;text-shadow:0 2px 14px rgba(0,0,0,0.25);">Kotlin<br />· Android</span>
  </div>
  <!-- Roulette ring -->
  <svg viewBox="0 0 200 200" style="position:absolute;top:14px;right:18px;width:90px;opacity:0.4;">
    <circle cx="100" cy="100" r="78" fill="none" stroke="white" stroke-width="2" stroke-dasharray="6 8"/>
    <circle cx="100" cy="100" r="58" fill="none" stroke="white" stroke-width="1" stroke-dasharray="2 5"/>
    <circle cx="100" cy="22" r="6" fill="white"/>
  </svg>
  <!-- Phone -->
  <svg viewBox="0 0 220 440" style="position:absolute;bottom:-40px;left:50%;width:56%;transform:translateX(-50%) rotate(-4deg);filter:drop-shadow(0 18px 28px rgba(0,0,0,0.22));">
    <rect x="6" y="6" width="208" height="428" rx="34" ry="34" fill="rgba(15,15,15,0.92)" stroke="rgba(255,255,255,0.9)" stroke-width="1.2"/>
    <rect x="14" y="22" width="192" height="396" rx="22" ry="22" fill="rgba(255,255,255,0.06)"/>
    <rect x="86" y="14" width="48" height="10" rx="5" fill="rgba(0,0,0,0.6)"/>
  </svg>
</TileBase>
