---
import TileBase from './TileBase.astro';
interface Props { screenshot?: string; }
const { screenshot } = Astro.props;
---

<TileBase
  gradient="linear-gradient(135deg, oklch(0.42 0.18 305) 0%, oklch(0.55 0.16 350) 60%, oklch(0.65 0.12 35) 100%)"
>
  <!-- Wordmark -->
  <div style="position:absolute;inset:0;display:flex;align-items:flex-start;justify-content:flex-start;padding:20px 22px;pointer-events:none;">
    <span style="font-family:var(--serif);font-style:italic;color:rgba(255,255,255,0.92);font-size:clamp(28px,4.4vw,56px);line-height:0.95;letter-spacing:-0.5px;text-shadow:0 2px 14px rgba(0,0,0,0.25);">React<br />· Capacitor</span>
  </div>
  <!-- Phone with screenshot inside -->
  <svg viewBox="0 0 220 440" style="position:absolute;bottom:-40px;left:50%;width:56%;transform:translateX(-50%) rotate(-8deg);filter:drop-shadow(0 18px 28px rgba(0,0,0,0.22));">
    <defs>
      <clipPath id="screen-clip">
        <rect x="14" y="22" width="192" height="396" rx="22" ry="22"/>
      </clipPath>
    </defs>
    <!-- Phone body -->
    <rect x="6" y="6" width="208" height="428" rx="34" ry="34" fill="rgba(15,15,15,0.92)" stroke="rgba(255,255,255,0.9)" stroke-width="1.2"/>
    <!-- Screenshot inside screen area -->
    {screenshot
      ? <image href={screenshot} x="14" y="22" width="192" height="396" clip-path="url(#screen-clip)" preserveAspectRatio="xMidYMin slice"/>
      : <rect x="14" y="22" width="192" height="396" rx="22" ry="22" fill="rgba(255,255,255,0.06)"/>
    }
    <!-- Notch -->
    <rect x="86" y="14" width="48" height="10" rx="5" fill="rgba(0,0,0,0.6)"/>
  </svg>
  <!-- Heart -->
  <svg viewBox="0 0 100 100" style="position:absolute;top:18px;right:22px;width:56px;opacity:0.18;">
    <path d="M50 82s-26-16-26-36c0-10 8-18 18-18 5 0 9 3 8 8 0-5 3-8 8-8 10 0 18 8 18 18 0 20-26 36-26 36z" fill="white"/>
  </svg>
</TileBase>
