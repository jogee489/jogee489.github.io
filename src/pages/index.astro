---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				display: flex;
				flex-direction: column;
				gap: 2rem;
			}
			.hero {
				padding: 3rem 0;
			}
			.hero h1 {
				margin: 0 0 0.25rem 0;
				font-size: 2.5rem;
			}
			.hero h2 {
				margin: 0 0 1rem 0;
				font-size: 1.25rem;
				font-weight: normal;
				color: rgb(var(--gray));
			}
			.hero p {
				font-size: 1.1rem;
				color: rgb(var(--gray-dark));
				max-width: 600px;
				margin: 0 0 2rem 0;
			}
			.cta-links {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}
			.cta-links a {
				padding: 0.6rem 1.2rem;
				border: 2px solid rgb(var(--accent));
				border-radius: 6px;
				text-decoration: none;
				color: rgb(var(--accent));
				font-weight: 600;
				transition: 0.2s ease;
			}
			.cta-links a:hover {
				background: rgb(var(--accent));
				color: white;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>JJ Dorko</h1>
				<h2>Senior Software Engineer</h2>
				<p>
					10+ years experience in backend and cross-platform development. Teaching English and
					building apps.
				</p>
				<div class="cta-links">
					<a href="/projects">View Projects</a>
					<a href="/about">About Me</a>
					<a href="https://github.com/jogee489" target="_blank">GitHub</a>
					<a href="https://www.linkedin.com/in/joseph-dorko-234721a9/" target="_blank">LinkedIn</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
