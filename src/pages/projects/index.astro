---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main { width: 960px; max-width: calc(100% - 2em); margin: auto; padding: 3em 1em; }
      ul { display: flex; flex-wrap: wrap; gap: 2rem; list-style: none; margin: 0; padding: 0; }
      ul li { width: calc(50% - 1rem); }
      .title { margin: 0; color: rgb(var(--black)); line-height: 1.2; }
      .role { margin: 4px 0 0; color: rgb(var(--gray)); font-size: 0.9em; }
      ul li a { display: block; text-decoration: none; }
      ul li a:hover .title { color: var(--accent); }
      @media (max-width: 720px) { ul li { width: 100%; } }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <ul>
        {projects.map(p => (
          <li>
            <a href={`/projects/${p.id}/`}>
              <h4 class="title">{p.data.name}</h4>
              <p class="role">{p.data.role} · {p.data.stack.join(', ')}</p>
            </a>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>
